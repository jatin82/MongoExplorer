# ── MongoExplorer environment configuration ────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed.

# REQUIRED. The access key users must type to reach the dashboard.
# Use a long, random, secret value. Example generator:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
APP_ACCESS_KEY=change-this-to-a-strong-secret

# Recommended. 256-bit key used to ENCRYPT the JWT session token.
# Provide ONE of:
#   - 64 hex characters (recommended):
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - a base64 value that decodes to exactly 32 bytes
#   - any passphrase (a 256-bit key is derived from it via scrypt)
# If left blank, an ephemeral key is derived from APP_ACCESS_KEY, which means
# all sessions are invalidated whenever the access key changes.
JWT_ENCRYPTION_KEY=

# How long an issued token stays valid: e.g. 30m, 8h, 7d, or bare seconds (3600).
JWT_TTL=8h

# Name of the cookie that stores the encrypted token.
AUTH_COOKIE_NAME=mongoExplorerAuth

# Set to "true" to mark the auth cookie Secure (HTTPS-only). Keep false for
# plain http on localhost.
COOKIE_SECURE=false

# Brute-force protection for the login endpoint.
AUTH_MAX_ATTEMPTS=8
AUTH_ATTEMPT_WINDOW=15m
AUTH_LOCK_DURATION=15m

# Express "trust proxy" setting. Set to "true" (or a hop count) when running
# behind a reverse proxy so client IPs are detected correctly for rate limiting.
TRUST_PROXY=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
# 127.0.0.1 keeps the server local-only. In Docker the container sets HOST=0.0.0.0.
HOST=127.0.0.1
